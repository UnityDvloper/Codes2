--  MONTA O HUB
-- ══════════════════════════════════════════════
local function MontarHub()
    local ok, Hub = pcall(function()
        return loadstring(game:HttpGet(
            "https://raw.githubusercontent.com/UnityDvloper/Codes/refs/heads/main/Hub",
            true
        ))()
    end)
    if not ok or not Hub then
        warn("[CimentoHub] Falha ao carregar modulo:", Hub)
        return
    end

    local hub = Hub.novo("Cimento ESP", "Escuro")

    -- ╔══════════════════════════════════════════╗
    -- ║  ABA: ESP                                ║
    -- ╚══════════════════════════════════════════╝
    local abaESP = hub:CriarAba("ESP", "👁️")

    -- ── INIMIGO ──────────────────────────────────
    abaESP:CriarSecao("ESP Inimigo")

    local espIniToggle = abaESP:CriarToggle("ESP Inimigo", Estado.espInimigo, function(v)
        Estado.espInimigo = v
        if v then
            IniciarESP()
            hub:Notificar("ESP Inimigo", "Ativado!", "sucesso", 2)
        else
            -- apenas remove os inimigos do ESP
            for _, plr in ipairs(Players:GetPlayers()) do
                local d = _espDados[plr.Name]
                if d and d.tipo == "inimigo" then RemoverEntradaESP(plr.Name) end
            end
            hub:Notificar("ESP Inimigo", "Desativado", "info", 2)
            -- se amigo também está off, para tudo
            if not Estado.espAmigo then LimparConexoes(_consESP) end
        end
    end)

    local tracerIniToggle = abaESP:CriarToggle("Tracers Inimigo", Estado.espTracersInimigo, function(v)
        Estado.espTracersInimigo = v
    end)

    abaESP:CriarSecao("Cores Inimigo")

    local cpFillIni = abaESP:CriarColorPicker("Fill (silhueta)", Estado.espFillInimigo, function(cor)
        Estado.espFillInimigo = cor
        for _, d in pairs(_espDados) do
            if d.tipo == "inimigo" then
                if d.hl      and d.hl.Parent      then d.hl.FillColor      = cor end
                if d.lblNome and d.lblNome.Parent then d.lblNome.TextColor3 = cor end
            end
        end
    end)

    local cpOutlineIni = abaESP:CriarColorPicker("Outline (contorno)", Estado.espOutlineInimigo, function(cor)
        Estado.espOutlineInimigo = cor
        for _, d in pairs(_espDados) do
            if d.tipo == "inimigo" then
                if d.hl     and d.hl.Parent     then d.hl.OutlineColor = cor end
                if d.stroke and d.stroke.Parent then d.stroke.Color    = cor end
            end
        end
    end)

    local cpTracerIni = abaESP:CriarColorPicker("Tracer (linha)", Estado.espTracerInimigo, function(cor)
        Estado.espTracerInimigo = cor
        for _, d in pairs(_espDados) do
            if d.tipo == "inimigo" and d.line then d.line.Color = cor end
        end
    end)

    -- ── AMIGO ─────────────────────────────────────
    abaESP:CriarSecao("ESP Amigo")

    local espAmiToggle = abaESP:CriarToggle("ESP Amigo", Estado.espAmigo, function(v)
        Estado.espAmigo = v
        if v then
            IniciarESP()
            hub:Notificar("ESP Amigo", "Ativado!", "sucesso", 2)
        else
            for _, plr in ipairs(Players:GetPlayers()) do
                local d = _espDados[plr.Name]
                if d and d.tipo == "amigo" then RemoverEntradaESP(plr.Name) end
            end
            hub:Notificar("ESP Amigo", "Desativado", "info", 2)
            if not Estado.espInimigo then LimparConexoes(_consESP) end
        end
    end)

    local tracerAmiToggle = abaESP:CriarToggle("Tracers Amigo", Estado.espTracersAmigo, function(v)
        Estado.espTracersAmigo = v
    end)

    abaESP:CriarSecao("Cores Amigo")

    local cpFillAmi = abaESP:CriarColorPicker("Fill (silhueta)", Estado.espFillAmigo, function(cor)
        Estado.espFillAmigo = cor
        for _, d in pairs(_espDados) do
            if d.tipo == "amigo" then
                if d.hl      and d.hl.Parent      then d.hl.FillColor      = cor end
                if d.lblNome and d.lblNome.Parent then d.lblNome.TextColor3 = cor end
            end
