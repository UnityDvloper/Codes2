    local cpTracerAmi = abaESP:CriarColorPicker("Tracer (linha)", Estado.espTracerAmigo, function(cor)
        Estado.espTracerAmigo = cor
        for _, d in pairs(_espDados) do
            if d.tipo == "amigo" and d.line then d.line.Color = cor end
        end
    end)

    -- ╔══════════════════════════════════════════╗
    -- ║  ABA: HITBOX                             ║
    -- ╚══════════════════════════════════════════╝
    local abaHitbox = hub:CriarAba("Hitbox", "🎯")
    abaHitbox:CriarSecao("Hitbox Expander")

    abaHitbox:CriarTexto(
        "Aplica apenas em INIMIGOS.\n"..
        "No lobby a hitbox volta ao normal automaticamente."
    )

    local hitboxToggle = abaHitbox:CriarToggle("Hitbox Expander", Estado.hitbox, function(v)
        Estado.hitbox = v
        if v then
            IniciarHitbox()
            hub:Notificar("Hitbox", "Ativado (tamanho x"..Estado.hitboxSize..")", "sucesso", 2.5)
        else
            PararHitbox()
            hub:Notificar("Hitbox", "Desativado - tamanhos restaurados", "info", 2.5)
        end
    end)

    abaHitbox:CriarSlider("Tamanho (multiplicador)", 2, 20, Estado.hitboxSize, function(v)
        Estado.hitboxSize = v
        if Estado.hitbox then
            -- reaplicar com novo tamanho
            RestaurarTodosHitbox()
            if EmPartida() then
                for _, plr in ipairs(Players:GetPlayers()) do
                    if ClassificarJogador(plr) == "inimigo" then
                        AplicarHitboxJogador(plr, v)
                    end
                end
            end
        end
    end)

    -- Transparência do HRP (0 = opaco, 100 = invisível)
    abaHitbox:CriarSlider("Transparência do HRP (0=opaco)", 0, 100, math.floor(Estado.hitboxTransp * 100), function(v)
        Estado.hitboxTransp = v / 100
        if Estado.hitbox and EmPartida() then
            -- aplica a transparência nos HRPs já expandidos sem resetar tamanho
            for _, plr in ipairs(Players:GetPlayers()) do
                if ClassificarJogador(plr) == "inimigo" then
                    local char = plr.Character
                    if char then
                        local hrp = char:FindFirstChild("HumanoidRootPart")
                        if hrp then
                            hrp.Transparency              = Estado.hitboxTransp
                            hrp.LocalTransparencyModifier = 0
                        end
                    end
                end
            end
        end
    end)

    abaHitbox:CriarSecao("Status")

    -- Label de status do time
    local lblStatus = abaHitbox:CriarTexto("Verificando time...")

    -- Atualiza label a cada segundo
    task.spawn(function()
        while not Estado.hubFechado do
            local meuTime = MeuTime()
            if meuTime then
                local inimigos = {}
                for _, plr in ipairs(Players:GetPlayers()) do
                    if ClassificarJogador(plr) == "inimigo" then
                        table.insert(inimigos, plr.Name)
                    end
                end
                local txt = "Time: "..meuTime.Name.."\n"
                if #inimigos > 0 then
                    txt = txt.."Inimigos ("..#inimigos.."):\n"
                    for _, n in ipairs(inimigos) do txt = txt.."  • "..n.."\n" end
                else
                    txt = txt.."Nenhum inimigo detectado"
                end
                lblStatus:Definir(txt)
            else
                lblStatus:Definir("Lobby — sem time atribuído\nHitbox será restaurada.")
            end
            task.wait(1)
        end
    end)

    -- ╔══════════════════════════════════════════╗
    -- ║  ABA: CONFIG                             ║
    -- ╚══════════════════════════════════════════╝
    local abaConfig = hub:CriarAba("Config", "⚙️")
    abaConfig:CriarSecao("Aparencia")
    hub:CriarDropdownTemas(abaConfig)
    abaConfig:CriarSecao("Info")
    abaConfig:CriarTexto(
        "Cimento ESP v1.0\n"..
        "ESP Inimigo + Amigo\n"..
        "Hitbox Expander (inimigos)\n"..
        "Detecção automática de time"
    )

    -- Ao fechar o hub
    hub:AoFechar(function() PararTudo() end)

    return hub
end

